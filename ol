indicator("Intraday Levels Pro [v5 VWAP Fixed]", true);

// ==========================================
// 1. User Inputs
// ==========================================

input.section("General & Styles");
const historyLevels = input.bool("History: Keep Levels", false);
const textSize = input.int("Text Size", 18, { min: 8, max: 40 });
const lineWidth = input.int("Line Width", 2, { min: 1, max: 10 });
const dashWidth = input.int("Dashed Width", 1, { min: 1, max: 10 });

input.section("Daily Levels");
const showOpen = input.bool("Show Daily Open", true);
const showPDHL = input.bool("Show PDH / PDL", true);
const showPrevVwap = input.bool("Show Prev Day VWAP", true);

const colorPDH = input.color("PDH Color", color.Red);
const colorPDL = input.color("PDL Color", color.Green);
const colorP_VWAP = input.color("Prev VWAP Color", color.Gray);

input.section("Weekly Levels");
const showWOpen = input.bool("Show Weekly Open", true);
const showPWHL = input.bool("Show PWH / PWL", true);
const colorWeek = input.color("Weekly Color", color.Yellow);

input.section("VWAP Settings");
const showVWAP = input.bool("Show Daily VWAP", true);
const showWVWAP = input.bool("Show Weekly VWAP", true);
const vwapPerfMode = input.bool("⚡ Use PlotLine (Fast)", true);
const historyVwap = input.bool("History: VWAP Trails (Slow)", false);

// ==========================================
// 2. Subscribe Data
// ==========================================
const candles = subscribe(data.OHLCV);

// ==========================================
// 3. Global State
// ==========================================

let lastDayIndex = -1;
let lastWeekIndex = -1;

let curDayHigh = -9e9,
  curDayLow = 9e9;
  let curWeekHigh = -9e9,
    curWeekLow = 9e9;
    let prevWeekHigh = 0,
      prevWeekLow = 0;
      let weeklyOpenPrice = 0;

      // Entity References (Daily)
      let openLine = null,
        openLabel = null;
        let pdhLine = null,
          pdhLabel = null;
          let pdlLine = null,
            pdlLabel = null;
            let pdVwapLine = null,
              pdVwapLabel = null;
              let vwapLabel = null;

              // Entity References (Weekly)
              let wOpenLine = null,
                wOpenLabel = null;
                let pwhLine = null,
                  pwhLabel = null;
                  let pwlLine = null,
                    pwlLabel = null;
                    let wVwapLabel = null;

                    // VWAP State
                    let vwapSumPv = 0,
                      vwapSumVol = 0;
                      let prevVwapValue = null,
                        prevVwapTime = null;

                        let wVwapSumPv = 0,
                          wVwapSumVol = 0;
                          let prevWVwapValue = null,
                            prevWVwapTime = null;

                            // ==========================================
                            // 4. Helper: Day Color
                            // ==========================================
                            function getDayColor(dayIndex) {
                              if (dayIndex === 1) return color.Red;
                                if (dayIndex === 2) return color.Orange;
                                  if (dayIndex === 3) return color.Yellow;
                                    if (dayIndex === 4) return color.Green;
                                      if (dayIndex === 5) return color.Teal;
                                        if (dayIndex === 6) return color.Blue;
                                          return color.Purple;
                                          }

                                          // ==========================================
                                          // 5. Main Logic
                                          // ==========================================
                                          function onBar(index) {
                                            const ts = candles.unix();
                                              if (!ts) return;

                                                const open = candles.open();
                                                  const high = candles.high();
                                                    const low = candles.low();
                                                      const close = candles.close();
                                                        const vol = candles.volume();
                                                          const hlc3 = (high + low + close) / 3;

                                                            const dateObj = new Date(ts * 1000);
                                                              const currentDay = dateObj.getUTCDate();
                                                                const weekDay = dateObj.getUTCDay();
                                                                  const isMonday = weekDay === 1;

                                                                    // Align Week to Monday
                                                                      const currentWeek = Math.floor((ts - 345600) / 604800);
                                                                        const todayColor = getDayColor(weekDay);

                                                                          // ------------------------------------------------
                                                                            // SECTION A: Weekly Logic
                                                                              // ------------------------------------------------
                                                                                if (currentWeek !== lastWeekIndex) {
                                                                                    if (lastWeekIndex !== -1) {
                                                                                          prevWeekHigh = curWeekHigh;
                                                                                                prevWeekLow = curWeekLow;
                                                                                                    }
                                                                                                        curWeekHigh = high;
                                                                                                            curWeekLow = low;
                                                                                                                weeklyOpenPrice = open;

                                                                                                                    wVwapSumPv = 0;
                                                                                                                        wVwapSumVol = 0;
                                                                                                                            prevWVwapValue = null;
                                                                                                                                prevWVwapTime = null;

                                                                                                                                    // --- Weekly Open ---
                                                                                                                                        if (showWOpen) {
                                                                                                                                              if (historyLevels) {
                                                                                                                                                      wOpenLine = null;
                                                                                                                                                              wOpenLabel = null;
                                                                                                                                                                    }

                                                                                                                                                                          if (wOpenLine) {
                                                                                                                                                                                  wOpenLine.set({
                                                                                                                                                                                            x1: ts,
                                                                                                                                                                                                      y1: weeklyOpenPrice,
                                                                                                                                                                                                                x2: ts,
                                                                                                                                                                                                                          y2: weeklyOpenPrice
                                                                                                                                                                                                                                  });
                                                                                                                                                                                                                                          wOpenLabel.set({ x: ts, y: weeklyOpenPrice });
                                                                                                                                                                                                                                                } else {
                                                                                                                                                                                                                                                        wOpenLine = Line({
                                                                                                                                                                                                                                                                  x1: ts,
                                                                                                                                                                                                                                                                            y1: weeklyOpenPrice,
                                                                                                                                                                                                                                                                                      x2: ts,
                                                                                                                                                                                                                                                                                                y2: weeklyOpenPrice,
                                                                                                                                                                                                                                                                                                          color: colorWeek,
                                                                                                                                                                                                                                                                                                                    width: lineWidth,
                                                                                                                                                                                                                                                                                                                              style: linestyle.Solid
                                                                                                                                                                                                                                                                                                                                      });
                                                                                                                                                                                                                                                                                                                                              wOpenLabel = Label({
                                                                                                                                                                                                                                                                                                                                                        x: ts,
                                                                                                                                                                                                                                                                                                                                                                  y: weeklyOpenPrice,
                                                                                                                                                                                                                                                                                                                                                                            text: "W-Open",
                                                                                                                                                                                                                                                                                                                                                                                      color: colorWeek,
                                                                                                                                                                                                                                                                                                                                                                                                size: textSize
                                                                                                                                                                                                                                                                                                                                                                                                        });
                                                                                                                                                                                                                                                                                                                                                                                                              }
                                                                                                                                                                                                                                                                                                                                                                                                                  }

                                                                                                                                                                                                                                                                                                                                                                                                                      // --- PWH / PWL ---
                                                                                                                                                                                                                                                                                                                                                                                                                          if (lastWeekIndex !== -1 && showPWHL) {
                                                                                                                                                                                                                                                                                                                                                                                                                                if (historyLevels) {
                                                                                                                                                                                                                                                                                                                                                                                                                                        pwhLine = null;
                                                                                                                                                                                                                                                                                                                                                                                                                                                pwhLabel = null;
                                                                                                                                                                                                                                                                                                                                                                                                                                                        pwlLine = null;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                pwlLabel = null;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                      }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                            if (pwhLine) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    pwhLine.set({
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              x1: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        y1: prevWeekHigh,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  x2: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            y2: prevWeekHigh
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            pwhLabel.set({ x: ts, y: prevWeekHigh });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    pwlLine.set({
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              x1: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        y1: prevWeekLow,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  x2: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            y2: prevWeekLow
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            pwlLabel.set({ x: ts, y: prevWeekLow });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  } else {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          pwhLine = Line({
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    x1: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              y1: prevWeekHigh,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        x2: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  y2: prevWeekHigh,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            color: colorWeek,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      width: dashWidth,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                style: linestyle.Dashed
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                pwhLabel = Label({
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          x: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    y: prevWeekHigh,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              text: "PWH",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        color: colorWeek,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  size: textSize
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  pwlLine = Line({
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            x1: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      y1: prevWeekLow,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                x2: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          y2: prevWeekLow,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    color: colorWeek,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              width: dashWidth,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        style: linestyle.Dashed
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        pwlLabel = Label({
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  x: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            y: prevWeekLow,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      text: "PWL",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                color: colorWeek,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          size: textSize
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                if (showWVWAP) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      if (wVwapLabel) wVwapLabel.set({ x: ts, y: close });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            else
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    wVwapLabel = Label({
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              x: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        y: close,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  text: "W-VWAP",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            color: colorWeek,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      size: textSize
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      lastWeekIndex = currentWeek;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        } else {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            // Intra-week
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                if (high > curWeekHigh) curWeekHigh = high;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    if (low < curWeekLow) curWeekLow = low;

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        if (wOpenLine && showWOpen) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              wOpenLine.set({ x2: ts });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    wOpenLabel.set({ x: ts });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            if (pwhLine && showPWHL) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  pwhLine.set({ x2: ts });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        pwhLabel.set({ x: ts });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                if (pwlLine && showPWHL) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      pwlLine.set({ x2: ts });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            pwlLabel.set({ x: ts });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    // ------------------------------------------------
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      // SECTION B: Daily Logic
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        // ------------------------------------------------
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          if (currentDay !== lastDayIndex) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              const isNewDay = true;

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  // --- Prev Day VWAP ---
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      if (lastDayIndex !== -1 && showPrevVwap && prevVwapValue !== null) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            const pVwapVal = prevVwapValue;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  if (historyLevels) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          pdVwapLine = null;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  pdVwapLabel = null;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              if (pdVwapLine) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      pdVwapLine.set({ x1: ts, y1: pVwapVal, x2: ts, y2: pVwapVal });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              pdVwapLabel.set({ x: ts, y: pVwapVal });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    } else {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            pdVwapLine = Line({
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      x1: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                y1: pVwapVal,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          x2: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    y2: pVwapVal,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              color: colorP_VWAP,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        width: dashWidth,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  style: linestyle.Dotted
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  pdVwapLabel = Label({
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            x: ts,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      y: pVwapVal,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                text: "P-VWAP",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          color: colorP_VWAP,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    size: textSize
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          // --- PDH / PDL ---
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              if (lastDayIndex !== -1 && showPDHL) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    if (historyLevels) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            pdhLine = null;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    pdhLabel = null;
